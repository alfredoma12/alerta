{
  "name": "stolen-car-backend",
  "version": "1.0.0",
  "description": "Minimal TypeScript backend for stolen car reports",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "npm run build && node dist/server.js"
  },
  "keywords": [
    "express",
    "typescript",
    "stolen-car",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2"
  }
}
